<div class="auth-container">
    <div class="auth-card text-center">
        <div class="auth-body py-5">
            <i class="bi bi-envelope-check text-primary" style="font-size: 3rem;"></i>
            <h3 class="fw-bold mt-3">Check your email</h3>
            <p class="text-muted">If an account exists for that email, we have sent password reset instructions.</p>
            <a asp-action="Login" class="btn btn-outline-primary mt-3 px-4">Back to Login</a>
        </div>
    </div>
</div>