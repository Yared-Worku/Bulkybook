<div class="auth-container">
    <div class="auth-card text-center">
        <div class="auth-body py-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
            <h3 class="fw-bold mt-3">Password Updated</h3>
            <p class="text-muted">Your password has been successfully reset. you can now log in with your new credentials.</p>
            <a asp-action="Login" class="btn btn-primary mt-3 px-4">Sign In Now</a>
        </div>
    </div>
</div>