@model ForgotPasswordViewModel
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h3 class="fw-bold mb-0">Reset Password</h3>
            <p class="small opacity-75">Enter your email to receive a reset link</p>
        </div>
        <div class="auth-body">
            <form asp-action="ForgotPassword" method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Email Address</label>
                    <div class="input-group auth-input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control auth-input" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <button type="submit" class="category-btn-edit btn-auth w-100">Send Link</button>
            </form>
        </div>
    </div>
</div>